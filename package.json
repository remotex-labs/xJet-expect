{
    "name": "@remotex-labs/xjet-expect",
    "main": "dist/cjs/index.js",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/esm/index.js",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "description": "xJet-Expect: Powerful Assertions for Seamless xJet Testing",
    "homepage": "https://remotex-labs.github.io/xJet-expect/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-labs/xJet-expect.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-labs/xJet-expect/issues"
    },
    "keywords": [
        "jet",
        "xjet",
        "test",
        "jest",
        "mocha",
        "watch",
        "testing",
        "mocking",
        "jasmine",
        "coverage",
        "typescript"
    ],
    "engines": {
        "node": ">=20"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm lint && pnpm test && pnpm build:clean"
    },
    "devDependencies": {
        "eslint": "^10.2.0",
        "vitepress": "^2.0.0-alpha.15",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.58.1",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-plugin-perfectionist": "^5.8.0",
        "@types/node": "^25.6.0",
        "@remotex-labs/xjet": "^1.5.4",
        "@viteplus/versions": "^2.0.6",
        "@remotex-labs/xbuild": "^2.4.0"
    },
    "dependencies": {
        "@remotex-labs/xansi": "^1.3.7"
    }
}
